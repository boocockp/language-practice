{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 120,
    "tabWidth": 4,
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "ignorePatterns": [
        "dist/**",
        "docs/**",
        "convex/_generated/**",
        "convex/vendor/**",
        "stuff/**",
        "scripts/**",
        ".cursor/**",
        "node_modules/**",
        "pnpm-workspace.yaml",
    ],
}
